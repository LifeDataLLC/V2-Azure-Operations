<!--
    - Policies are applied in the order they appear.
    - Position <base/> inside a section to inherit policies from the outer scope.
    - Comments within policies are not preserved.
-->
<!-- Add policies as children to the <inbound>, <outbound>, <backend>, and <on-error> elements -->
<policies>
	<!-- Throttle, authorize, validate, cache, or transform the requests -->
	<inbound>
		<base />
		<include-fragment fragment-id="CORSPolicy" />
		<include-fragment fragment-id="WebAccessTokenValidatePolicy" />
		<set-header name="Authorization" exists-action="override">
			<value>@(context.Request.Headers.GetValueOrDefault("Authorization"))</value>
		</set-header>
		<set-variable name="AuthorizationHeader" value="@(context.Request.Headers.GetValueOrDefault("Authorization"))" />
		<send-request ignore-error="true" timeout="30" response-variable-name="TokenParser" mode="new">
			<set-url>https://user-module-staging-eastus.azurewebsites.net/user/getUserIDForLoggedInUser</set-url>
			<set-method>GET</set-method>
			<set-header name="Authorization" exists-action="override">
				<value>@(context.Variables.GetValueOrDefault<string>("AuthorizationHeader"))</value>
			</set-header>
		</send-request>
		<choose>
			<when condition="@(context.Variables.GetValueOrDefault<IResponse>("TokenParser").StatusCode == 200)">
				<set-query-parameter name="UserID" exists-action="skip">
					<value>@{
                        string UserID = (string)((IResponse)context.Variables["TokenParser"]).Body.As<JObject>()["UserID"];
                        return UserID;
                    }</value>
				</set-query-parameter>
			</when>
			<otherwise>
				<return-response>
					<set-status code="401" reason="User Not Allowed" />
				</return-response>
			</otherwise>
		</choose>
	</inbound>
	<!-- Control if and how the requests are forwarded to services  -->
	<backend>
		<base />
	</backend>
	<!-- Customize the responses -->
	<outbound>
		<base />
	</outbound>
	<!-- Handle exceptions and customize error responses  -->
	<on-error>
		<base />
	</on-error>
</policies>