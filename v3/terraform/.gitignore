# Terraform working directory — never commit
.terraform/

# State files — never commit (remote state is on Azure Blob)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log
crash.log

# Sensitive variable files
*.tfvars
!*.backend.hcl
